<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Informe de Turnos por Especialidad</title>

    <style>

        body{
            font-family: Arial, Helvetica, sans-serif;
            margin: 30px;
            color: #333;
        }

        .encabezado{
            text-align: center;
            margin-bottom: 30px;
        }

        .encabezado h1{
            margin: 0;
        }

        .encabezado p{
            margin: 5px 0;
        }

        .info{
            margin-bottom: 20px;
        }

        .info p{
            margin: 4px 0;
        }

        table{
            width: 100%;
            border-collapse: collapse;
        }

        th{
            border: 1px solid #000;
            padding: 10px;
            background-color: #f2f2f2;
        }

        td{
            border: 1px solid #000;
            padding: 8px;
        }

        .texto-derecha{
            text-align: right;
        }

        .texto-centro{
            text-align: center;
        }

        .total{
            font-weight: bold;
            background-color: #f5f5f5;
        }

        .footer{
            margin-top: 30px;
            text-align: center;
            font-size: 12px;
            color: gray;
        }

    </style>

</head>
<body>

    <div class="encabezado">
        <h1>Informe de Turnos por Especialidad</h1>
        <p>Sistema de Gestión de Turnos Médicos</p>
    </div>

    <table>

        <thead>
            <tr>
                <th>Especialidad</th>
                <th>Cantidad de Turnos</th>
                <th>Facturación Total</th>
            </tr>
        </thead>

        <tbody>

            {{#each especialidades}}
            <tr>
                <td>
                    {{especialidad}}
                </td>

                <td class="texto-centro">
                    {{cantidad_turnos}}
                </td>

                <td class="texto-derecha">
                    $ {{facturacion_total}}
                </td>
            </tr>
            {{/each}}

        </tbody>

    </table>

</body>
</html>